---
import Layout from "../../layouts/Layout.astro";
import { PRODUCTS } from "../../data/shop.products";
import ProductActions from "../../components/shop/ui/ProductActions";
import ProductCard from "../../components/landing/ProductCard.astro";
import { fmtPrice } from "../../components/shop/ui/ShopAtoms";

export async function getStaticPaths() {
    // We map all products to their unique ID paths
    return PRODUCTS.map((product) => ({
        params: { id: product.id.toString() },
        props: { product },
    }));
}

const { id } = Astro.params;
let { product } = Astro.props;

// Extremely robust lookup: 
// 1. Convert id to integer for comparison
// 2. Search PRODUCTS data directly to ensure total data parity
if (id) {
    const numericId = parseInt(id, 10);
    const foundProduct = PRODUCTS.find(p => p.id === numericId);
    if (foundProduct) {
        product = foundProduct;
    }
}

// Final safety check
if (!product) {
    return Astro.redirect('/shop');
}

// Filter related products
const relatedProducts = PRODUCTS.filter(
    (p) => p.category === product.category && p.id !== product.id
).slice(0, 4);
---

<Layout title={`${product.name} | Triostepdkhyber`}>
    <main class="bg-white">
        {/* Breadcrumbs */}
        <nav class="max-w-[1440px] mx-auto px-6 py-6 border-b border-gray-50">
            <ol class="flex items-center gap-3 text-[10px] uppercase tracking-[0.2em] font-bold text-gray-400">
                <li><a href="/" class="hover:text-dark transition-colors">Home</a></li>
                <li class="text-gray-200">/</li>
                <li><a href="/shop" class="hover:text-dark transition-colors">Catalog</a></li>
                <li class="text-gray-200">/</li>
                <li class="text-dark">{product.name}</li>
            </ol>
        </nav>

        {/* Main Product Section */}
        <section class="max-w-[1440px] mx-auto px-6 py-12 md:py-20">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 xl:gap-24 items-start">
                
                {/* Image Gallery */}
                <div class="lg:col-span-7 grid grid-cols-1 gap-4">
                    <div class="aspect-[4/5] bg-[#F9F9F9] overflow-hidden relative group">
                         <img 
                            src={product.image} 
                            alt={product.name} 
                            class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
                         />
                         {product.badge && (
                            <span class="absolute top-8 left-8 bg-dark text-white text-[10px] font-black uppercase tracking-[0.3em] px-4 py-2">
                                {product.badge}
                            </span>
                         )}
                    </div>
                    {/* Secondary images placeholders to make it look "professional" */}
                    <div class="grid grid-cols-2 gap-4">
                        <div class="aspect-[4/5] bg-[#F9F9F9] opacity-80 hover:opacity-100 transition-opacity">
                             <img src={product.image} class="w-full h-full object-cover grayscale" />
                        </div>
                        <div class="aspect-[4/5] bg-[#F9F9F9] opacity-80 hover:opacity-100 transition-opacity">
                             <img src={product.image} class="w-full h-full object-cover sepia-[.2]" />
                        </div>
                    </div>
                </div>

                {/* Product Info */}
                <div class="lg:col-span-5 lg:sticky lg:top-32">
                    <div class="mb-10">
                        <span class="text-[11px] uppercase tracking-[0.4em] text-gray-400 font-black mb-4 block">
                            {product.category}
                        </span>
                        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-dark mb-4 uppercase">
                            {product.name}
                        </h1>
                        <div class="flex items-center gap-4">
                            <div class="flex text-dark text-xs gap-0.5">
                                {[...Array(5)].map((_, i) => (
                                    <span class={i < Math.round(product.rating) ? 'opacity-100' : 'opacity-20'}>●</span>
                                ))}
                            </div>
                            <span class="text-[10px] uppercase tracking-widest text-gray-400 font-bold">Based on {product.reviews} reviews</span>
                        </div>
                    </div>

                    <ProductActions product={product} client:load />

                    {/* Trust badges */}
                    <div class="mt-12 grid grid-cols-3 gap-4 border-t border-gray-100 pt-10">
                        <div class="text-center">
                            <div class="text-[9px] font-black uppercase tracking-widest text-dark mb-1 italic">Free Express</div>
                            <div class="text-[8px] uppercase tracking-widest text-gray-400">Shipping</div>
                        </div>
                        <div class="text-center">
                            <div class="text-[9px] font-black uppercase tracking-widest text-dark mb-1 italic">30 Day</div>
                            <div class="text-[8px] uppercase tracking-widest text-gray-400">Returns</div>
                        </div>
                        <div class="text-center">
                            <div class="text-[9px] font-black uppercase tracking-widest text-dark mb-1 italic">Lifetime</div>
                            <div class="text-[8px] uppercase tracking-widest text-gray-400">Guarantee</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* You May Also Like */}
        {relatedProducts.length > 0 && (
            <section class="max-w-[1440px] mx-auto px-6 py-24 border-t border-gray-100">
                <h2 class="text-xl md:text-2xl font-bold uppercase tracking-tight text-dark mb-12">Complete The Look</h2>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
                    {relatedProducts.map((p) => (
                        <ProductCard
                            id={p.id}
                            title={p.name}
                            priceLabel={fmtPrice(p.price)}
                            imageSrc={p.image}
                            imageAlt={p.name}
                        />
                    ))}
                </div>
            </section>
        )}
    </main>
</Layout>
