---
import Layout from "../layouts/Layout.astro";
import { CATEGORIES, PRODUCTS } from "../data/shop.products";

// Get one representative image for each category
const collections = CATEGORIES.filter(c => c !== 'All').map(category => {
    const product = PRODUCTS.find(p => p.category === category);
    return {
        name: category,
        image: product?.image || PRODUCTS[0].image,
        count: PRODUCTS.filter(p => p.category === category).length
    };
});
---

<Layout title="Collections | Triostepdkhyber">
    <main class="bg-white">
        {/* Editorial Header */}
        <section class="max-w-[1440px] mx-auto px-6 py-24 md:py-32 border-b border-gray-50">
            <div class="max-w-3xl">
                <span class="text-[10px] uppercase tracking-[0.5em] text-gray-400 font-black mb-6 block">The Curation</span>
                <h1 class="text-6xl md:text-[8rem] font-bold uppercase leading-[0.8] tracking-tighter text-dark mb-12">
                    Master <br/> <span class="text-gray-200">Collections</span>
                </h1>
                <p class="text-[13px] uppercase tracking-[0.2em] font-light max-w-sm text-gray-500 leading-relaxed">
                    Explore our diverse architectural silhouettes, each designed with a specific aesthetic and structural purpose in mind.
                </p>
            </div>
        </section>

        {/* Collections Grid */}
        <section class="max-w-[1440px] mx-auto px-6 py-20">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                {collections.map((col, i) => (
                    <a href={`/shop?category=${col.name}`} class="group block relative overflow-hidden">
                        <div class="aspect-[16/10] bg-gray-100 overflow-hidden">
                            <img 
                                src={col.image} 
                                alt={col.name} 
                                class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
                            />
                        </div>
                        <div class="mt-8 flex justify-between items-end">
                            <div>
                                <span class="text-[10px] uppercase tracking-[0.3em] text-gray-400 font-black mb-2 block">0{i + 1}</span>
                                <h3 class="text-3xl font-bold uppercase tracking-tighter text-dark">{col.name}</h3>
                            </div>
                            <div class="text-right">
                                <span class="text-[10px] uppercase tracking-[0.2em] font-black text-gray-300 block mb-1">{col.count} Articles</span>
                                <span class="text-[11px] uppercase tracking-[0.4em] font-black text-dark group-hover:translate-x-2 transition-transform inline-block">View Full →</span>
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        </section>

        {/* Brand Statement */}
        <section class="bg-dark py-32 mt-20 overflow-hidden relative">
            <div class="max-w-[1440px] mx-auto px-6 relative z-10 text-center">
                <h2 class="text-white text-4xl md:text-6xl font-bold uppercase tracking-tighter leading-tight mb-12">
                    Handcrafted for the <br/> Modern <span class="text-gray-500 italic font-light">Minimalist</span>
                </h2>
                <a href="/shop" class="inline-block border border-white/20 px-12 py-5 text-[10px] uppercase tracking-[0.5em] text-white font-black hover:bg-white hover:text-dark transition-all duration-500">
                    Discover More
                </a>
            </div>
            <div class="absolute inset-0 opacity-10 flex items-center justify-center">
                <span class="text-[20vw] font-black text-white uppercase tracking-tighter select-none">TRIOSTEP</span>
            </div>
        </section>
    </main>
</Layout>
