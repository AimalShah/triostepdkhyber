---
/**
 * ShopHero — editorial banner above the product catalog.
 * Mirrors the design pattern from HeroSection.astro.
 */
---

<!-- Editorial Hero Section -->
<section class="w-full relative bg-dark overflow-hidden min-h-[50vh] md:min-h-[60vh] flex flex-col justify-center">
    <!-- Main Background Image -->
    <div class="absolute inset-0 z-0">
        <img
            alt="Editorial Campaign"
            class="w-full h-full object-cover object-center opacity-80 mix-blend-luminosity scale-105"
            src="https://images.unsplash.com/photo-1630837792758-604e4bd13e2c?w=1600&auto=format&fit=crop&q=80"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-dark/90 via-dark/40 to-transparent"></div>
    </div>

    <!-- Content Overlay -->
    <div class="relative z-10 max-w-[1440px] mx-auto px-6 w-full py-20">
        <div class="max-w-2xl">
            <span class="text-[10px] uppercase tracking-[0.5em] text-gray-400 font-black mb-6 block">Collection 2024</span>
            <h1 class="font-display text-6xl md:text-[8rem] font-bold uppercase leading-[0.8] tracking-tighter text-white mb-8">
                The <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-500">Archive</span>
            </h1>
            <div class="flex flex-col md:flex-row md:items-center gap-8 md:gap-12 mt-12 border-l border-white/20 pl-8">
                <p class="text-[12px] uppercase tracking-[0.2em] font-light max-w-xs text-gray-300 leading-relaxed">
                    A comprehensive curation of footwear, merging architectural silhouettes with timeless craftsmanship.
                </p>
                <div class="flex items-center gap-4">
                    <div class="w-12 h-px bg-white/40"></div>
                    <span class="text-[10px] uppercase tracking-[0.3em] font-black text-white italic">Explore All {71} Styles</span>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Subtle Geometric Detail -->
    <div class="absolute bottom-0 right-0 w-1/3 h-full border-l border-white/5 pointer-events-none hidden md:block"></div>
</section>
