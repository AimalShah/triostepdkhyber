---
import WishlistToggle from "../shop/ui/WishlistToggle";

import type { Product } from "../../data/shop.products";
import { fmtPrice } from "../../components/shop/ui/ShopAtoms";

interface Props {
    products: Product[];
}

const { products } = Astro.props;
---

<div
    class="md:hidden w-screen pb-2 -mx-6 px-0 border border-gray-200 border-t border-b bg-white box-border max-w-screen"
>
    <div
        id="new-arrivals-mobile-swiper"
        class="swiper new-arrivals-swiper w-full overflow-hidden"
    >
        <div class="swiper-wrapper">
            {
                products.map((product, idx) => (
                    <div
                        class:list={[
                            "swiper-slide !h-auto box-border",
                            idx % 2 === 0 ? "border-r border-gray-200" : "",
                            idx >= 2 ? "border-t border-gray-200" : "",
                        ]}
                    >
                        <div class="relative group flex flex-col w-full h-full p-2 bg-white">
                            <div class="relative aspect-[4/5] overflow-hidden bg-[#F8F8F8] mb-3">
                                <div class="absolute top-2 right-2 z-20 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                                    <WishlistToggle productId={product.id} client:load />
                                </div>
                                
                                <a href={`/product/${product.id}`} class="block w-full h-full">
                                    <img class="w-full h-full object-cover mix-blend-multiply transition-transform duration-[1.5s] ease-out group-hover:scale-110" src={product.image} alt={product.name} loading="lazy" />
                                </a>

                                <a href={`/product/${product.id}`} class="absolute bottom-0 left-0 right-0 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] z-20 block text-center no-underline">
                                    <div class="w-full bg-dark/95 backdrop-blur-md text-white py-3 text-[9px] uppercase tracking-[0.2em] font-bold hover:bg-black transition-colors">
                                      View Details
                                    </div>
                                </a>
                            </div>
                            
                            <a href={`/product/${product.id}`} class="flex flex-col text-center px-1 pb-2 no-underline text-inherit group-hover:text-gray-600 transition-colors z-10">
                                <h3 class="text-[11px] font-bold uppercase tracking-widest text-dark mb-1 truncate px-2">{product.name}</h3>
                                <p class="text-[11px] font-bold tracking-widest text-gray-600">{fmtPrice(product.price)}</p>
                            </a>
                        </div>
                    </div>
                ))
            }
        </div>
        <div
            id="new-arrivals-swiper-pagination"
            class="swiper-pagination !relative !bottom-auto py-5 border-t border-gray-200 bg-white justify-center gap-2"
        >
        </div>
    </div>
</div>

<script>
    import Swiper from "swiper";
    import { Autoplay, Pagination } from "swiper/modules";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    import "swiper/css";
    import "swiper/css/pagination";

    function mount() {
        const root = document.getElementById("new-arrivals-mobile-swiper");
        const paginationEl = document.getElementById(
            "new-arrivals-swiper-pagination",
        );
        if (
            !root?.querySelector(".swiper-slide") ||
            !paginationEl ||
            root.dataset.swiperMounted
        )
            return;

        root.dataset.swiperMounted = "true";

        new Swiper(root, {
            modules: [Pagination, Autoplay],
            slidesPerView: 2,
            spaceBetween: 0,
            watchSlidesProgress: true,
            loop: true,
            speed: 650,
            autoplay: {
                delay: 2500,
                disableOnInteraction: false,
                pauseOnMouseEnter: true,
            },
        });

        ScrollTrigger.refresh();
        requestAnimationFrame(() => ScrollTrigger.refresh());
        setTimeout(() => ScrollTrigger.refresh(), 400);
    }

    if (document.readyState !== "loading") mount();
    document.addEventListener("DOMContentLoaded", mount);
</script>
