---
import WishlistToggle from "../shop/ui/WishlistToggle";

import type { Product } from "../../data/shop.products";
import { fmtPrice } from "../../components/shop/ui/ShopAtoms";

interface Props {
    products: Product[];
}

const { products } = Astro.props;
---

<div
    class="md:hidden w-screen pb-2 -mx-6 px-0 border border-gray-200 border-t border-b bg-white box-border max-w-screen"
>
    <div
        id="new-arrivals-mobile-swiper"
        class="swiper new-arrivals-swiper w-full overflow-hidden"
    >
        <div class="swiper-wrapper">
            {
                products.slice(0, 8).map((product, idx) => (
                    <div
                        class:list={[
                            "swiper-slide !h-auto box-border",
                            idx % 2 === 0 ? "border-r border-gray-100" : "",
                            idx >= 2 ? "border-t border-gray-100" : "",
                        ]}
                    >
                        <div class="relative group flex flex-col w-full h-full p-4 bg-white transition-all">
                            <div class="relative aspect-[4/5] overflow-hidden bg-[#F9F9F9] mb-4">
                                <div class="absolute top-3 right-3 z-20 opacity-0 group-hover:opacity-100 transition-all duration-500 translate-x-2 group-hover:translate-x-0">
                                    <WishlistToggle productId={product.id} client:load />
                                </div>
                                
                                <a href={`/product/${product.id}`} class="block w-full h-full relative">
                                    <img class="w-full h-full object-cover transition-all duration-[1.5s] ease-out group-hover:scale-110" src={product.image} alt={product.name} loading="lazy" />
                                    <div class="absolute inset-0 bg-dark/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                                </a>

                                <a href={`/product/${product.id}`} class="absolute bottom-0 left-0 right-0 p-2 translate-y-full group-hover:translate-y-0 transition-transform duration-500 z-20 block text-center no-underline">
                                    <div class="w-full bg-white text-dark py-3 text-[8px] uppercase tracking-[0.2em] font-black hover:bg-dark hover:text-white transition-all shadow-lg border border-gray-100">
                                      Quick View +
                                    </div>
                                </a>
                            </div>
                            
                            <a href={`/product/${product.id}`} class="flex flex-col text-left no-underline text-inherit group-hover:text-gray-500 transition-colors z-10">
                                <p class="text-[8px] uppercase tracking-[0.25em] text-gray-400 font-bold mb-1">New Arrival</p>
                                <h3 class="text-[12px] font-bold tracking-tight text-dark mb-2 truncate">{product.name}</h3>
                                <p class="text-[12px] font-bold tracking-tighter text-dark">{fmtPrice(product.price)}</p>
                            </a>
                        </div>
                    </div>
                ))
            }
        </div>
        <div
            id="new-arrivals-swiper-pagination"
            class="swiper-pagination !relative !bottom-auto py-5 border-t border-gray-200 bg-white justify-center gap-2"
        >
        </div>
    </div>
</div>

<script>
    import Swiper from "swiper";
    import { Autoplay, Pagination } from "swiper/modules";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    import "swiper/css";
    import "swiper/css/pagination";

    function mount() {
        const root = document.getElementById("new-arrivals-mobile-swiper");
        const paginationEl = document.getElementById(
            "new-arrivals-swiper-pagination",
        );
        if (
            !root?.querySelector(".swiper-slide") ||
            !paginationEl ||
            root.dataset.swiperMounted
        )
            return;

        root.dataset.swiperMounted = "true";

        new Swiper(root, {
            modules: [Pagination, Autoplay],
            slidesPerView: 2,
            spaceBetween: 0,
            watchSlidesProgress: true,
            loop: true,
            speed: 650,
            autoplay: {
                delay: 2500,
                disableOnInteraction: false,
                pauseOnMouseEnter: true,
            },
        });

        ScrollTrigger.refresh();
        requestAnimationFrame(() => ScrollTrigger.refresh());
        setTimeout(() => ScrollTrigger.refresh(), 400);
    }

    if (document.readyState !== "loading") mount();
    document.addEventListener("DOMContentLoaded", mount);
</script>
