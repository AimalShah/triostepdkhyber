---
import logoImg from "../../assets/images/1000151679.jpg.jpeg";

const navLinks = [
    { label: "Catalog", href: "/shop" },
    { label: "Collections", href: "/shop" },
    { label: "Sale", href: "/shop" },
    { label: "About Brand", href: "/about" },
] as const;

const utilLinks = [
    { label: "Account", href: "#" },
    { label: "Search", href: "#" },
    { label: "Favorites", href: "/wishlist" },
    { label: "Cart(0)", href: "/shop" },
] as const;
---

<!-- BEGIN: Navigation -->
<header
    class="w-full bg-white border-b border-gray-200 sticky top-0 z-50 backdrop-blur-sm bg-white/95"
>
    <div
        class="max-w-[1440px] mx-auto px-4 sm:px-6 py-4 flex justify-between items-center gap-4"
    >
        <a class="shrink-0" href="/">
            <img src={logoImg.src} alt="Triostepdkhyber Logo" class="h-10 w-auto object-contain" />
        </a>
        <nav
            class="hidden md:flex flex-1 justify-center gap-8 text-[11px] uppercase tracking-wider font-medium"
        >
            {
                navLinks.map(({ label, href }) => (
                    <a
                        class="hover:text-gray-500 transition-colors whitespace-nowrap"
                        href={href}
                    >
                        {label}
                    </a>
                ))
            }
        </nav>
        <div class="flex items-center gap-3 sm:gap-6 shrink-0 min-w-0">
            <div
                class="flex items-center gap-3 sm:gap-6 text-[10px] sm:text-[11px] uppercase tracking-wider font-medium overflow-x-auto max-w-[min(100vw-8rem,360px)] sm:max-w-none [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden whitespace-nowrap"
            >
                {
                    utilLinks.map(({ label, href }) => (
                        <a
                            class="hover:text-gray-500 transition-colors shrink-0"
                            href={href}
                        >
                            {label}
                        </a>
                    ))
                }
            </div>
        </div>
    </div>
</header>
<!-- END: Navigation -->
