---
import logoImg from "../../assets/images/1000151679.jpg.jpeg";

const navLinks = [
    { label: "Catalog", href: "/shop" },
    { label: "Collections", href: "/collections" },
    { label: "Sale", href: "/sale" },
    { label: "About Brand", href: "/about" },
] as const;

const utilLinks = [
    { label: "Account", href: "/shop" },
    { label: "Search", href: "/shop" },
    { label: "Favorites", href: "/wishlist" },
    { label: "Cart(0)", href: "/shop" },
] as const;
---

<!-- BEGIN: Navigation -->
<header
    class="w-full bg-white/95 border-b border-gray-100 sticky top-0 z-[100] backdrop-blur-md"
>
    <div
        class="max-w-[1440px] mx-auto px-6 py-5 flex justify-between items-center gap-4"
    >
        {/* Logo */}
        <a class="shrink-0 relative z-[110]" href="/">
            <img src={logoImg.src} alt="Triostepdkhyber Logo" class="h-9 w-auto object-contain" />
        </a>

        {/* Desktop Nav - Centered */}
        <nav
            class="hidden md:flex flex-1 justify-center gap-6 lg:gap-10 text-[11px] uppercase tracking-[0.25em] font-black text-dark"
        >
            {
                navLinks.map(({ label, href }) => (
                    <a
                        class="hover:text-gray-400 transition-all relative after:absolute after:bottom-[-4px] after:left-0 after:h-[1px] after:bg-dark after:w-0 hover:after:w-full after:transition-all"
                        href={href}
                    >
                        {label}
                    </a>
                ))
            }
        </nav>

        {/* Desktop Actions */}
        <div class="hidden md:flex items-center gap-4 lg:gap-8 shrink-0">
            {
                utilLinks.map(({ label, href }) => (
                    <a
                        class="text-[10px] uppercase tracking-[0.2em] font-bold hover:text-gray-400 transition-colors"
                        href={href}
                    >
                        {label}
                    </a>
                ))
            }
        </div>

        {/* Mobile Controls */}
        <div class="flex md:hidden items-center gap-6 relative z-[110]">
             <a href="/wishlist" class="text-dark hover:scale-110 transition-transform">
                <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" strokeWidth="1.5">
                    <path d="M12 21C12 21 3 14.5 3 8.5C3 5.46 5.46 3 8.5 3C10.24 3 11.91 3.81 13 5.09C14.09 3.81 15.76 3 17.5 3C20.54 3 23 5.46 23 8.5C23 14.5 14 21 12 21Z" />
                </svg>
             </a>
             <button id="mobile-menu-toggle" class="relative w-8 h-8 flex items-center justify-center group" aria-label="Toggle Menu">
                <div class="w-6 flex flex-col gap-1.5 transition-all duration-500">
                    <span id="line-top" class="w-full h-[1.5px] bg-dark origin-center transition-all duration-500"></span>
                    <span id="line-mid" class="w-full h-[1.5px] bg-dark transition-all duration-500"></span>
                    <span id="line-bot" class="w-full h-[1.5px] bg-dark origin-center transition-all duration-500"></span>
                </div>
             </button>
        </div>
    </div>

    {/* Elite Mobile Menu Overlay */}
    <div id="mobile-menu-overlay" class="fixed inset-0 bg-white z-[105] clip-path-hidden lg:hidden">
        <div class="h-full flex flex-col px-8 pt-24 pb-12 relative overflow-hidden">
            {/* Header section in menu */}
            <div class="flex justify-between items-center mb-12 mobile-menu-link opacity-0">
                <span class="text-[10px] uppercase tracking-[0.4em] text-gray-400 font-black">Menu</span>
                <div class="h-px flex-1 bg-gray-100 mx-6"></div>
            </div>

            <nav class="flex flex-col relative z-10 flex-1">
                {
                    [
                        { label: "New Arrivals", href: "/shop" },
                        { label: "Shop All",      href: "/shop" },
                        { label: "Collections",   href: "/collections" },
                        { label: "Seasonal Sale", href: "/sale" },
                        { label: "Wishlist",      href: "/wishlist" },
                        { label: "Our Story",     href: "/about" }
                    ].map(({ label, href }, i) => (
                        <a
                            class="mobile-menu-link py-5 border-b border-gray-50 text-2xl font-bold uppercase tracking-tight text-dark opacity-0 flex justify-between items-center group"
                            href={href}
                        >
                            <span>{label}</span>
                            <svg viewBox="0 0 24 24" class="w-4 h-4 text-gray-300 group-hover:text-dark transition-colors" fill="none" stroke="currentColor" strokeWidth="2">
                                <path d="M9 18l6-6-6-6" />
                            </svg>
                        </a>
                    ))
                }
            </nav>
            
            {/* Professional Footer Actions */}
            <div class="mt-auto relative z-10">
                <div class="grid grid-cols-2 gap-4 mb-10 mobile-menu-link opacity-0">
                    <a href="/shop" class="bg-gray-50 py-4 text-center text-[10px] uppercase tracking-[0.3em] font-black hover:bg-dark hover:text-white transition-all">Account</a>
                    <a href="/wishlist" class="bg-gray-50 py-4 text-center text-[10px] uppercase tracking-[0.3em] font-black hover:bg-dark hover:text-white transition-all">Support</a>
                </div>
                
                <div class="flex justify-between items-center mobile-menu-link opacity-0">
                    <div>
                        <p class="text-[9px] uppercase tracking-[0.3em] text-gray-400 mb-1">Inquiries</p>
                        <a href="mailto:support@triostepdkhyber.com" class="text-[11px] font-bold text-dark">support@triostepdkhyber.com</a>
                    </div>
                    <div class="flex gap-4">
                        {['IG', 'TG'].map(s => (
                            <div class="w-8 h-8 rounded-full border border-gray-100 flex items-center justify-center text-[9px] font-black">{s}</div>
                        ))}
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<style>
    .clip-path-hidden {
        clip-path: circle(0% at 90% 5%);
    }
</style>

<script>
    import gsap from 'gsap';

    function initMobileMenu() {
        const toggle = document.getElementById('mobile-menu-toggle');
        const overlay = document.getElementById('mobile-menu-overlay');
        const links = document.querySelectorAll('.mobile-menu-link');
        
        const lineTop = document.getElementById('line-top');
        const lineMid = document.getElementById('line-mid');
        const lineBot = document.getElementById('line-bot');
        
        let isOpen = false;

        if (!toggle || !overlay) return;

        toggle.addEventListener('click', () => {
            isOpen = !isOpen;
            
            if (isOpen) {
                // Animate Toggle to X
                gsap.to(lineTop, { rotation: 45, y: 7.5, duration: 0.5, ease: "power4.inOut" });
                gsap.to(lineMid, { opacity: 0, scaleX: 0, duration: 0.3 });
                gsap.to(lineBot, { rotation: -45, y: -7.5, duration: 0.5, ease: "power4.inOut" });

                // Reveal Overlay with Circle Clip Path
                gsap.to(overlay, {
                    clipPath: "circle(150% at 90% 5%)",
                    duration: 1.2,
                    ease: "power4.inOut"
                });

                // Staggered Link Animation
                gsap.to(links, {
                    opacity: 1,
                    x: 0,
                    stagger: 0.1,
                    duration: 0.8,
                    delay: 0.4,
                    ease: "power4.out"
                });
            } else {
                // Animate X back to Hamburger
                gsap.to(lineTop, { rotation: 0, y: 0, duration: 0.5, ease: "power4.inOut" });
                gsap.to(lineMid, { opacity: 1, scaleX: 1, duration: 0.5 });
                gsap.to(lineBot, { rotation: 0, y: 0, duration: 0.5, ease: "power4.inOut" });

                // Hide Overlay
                gsap.to(overlay, {
                    clipPath: "circle(0% at 90% 5%)",
                    duration: 0.8,
                    ease: "power4.inOut"
                });

                // Reset Links
                gsap.to(links, {
                    opacity: 0,
                    x: -20,
                    duration: 0.3
                });
            }
        });
        
        // Initial state
        gsap.set(links, { x: -20, opacity: 0 });
    }

    document.addEventListener('DOMContentLoaded', initMobileMenu);
    document.addEventListener('astro:page-load', initMobileMenu);
</script>
<!-- END: Navigation -->
