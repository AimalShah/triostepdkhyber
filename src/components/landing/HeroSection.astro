---
const carouselData = [
  {
    image: "https://images.unsplash.com/photo-1490481651871-ab68de25d43d?q=80&w=2070&auto=format&fit=crop",
    alt: "Heritage Collection Look 1",
    title: "TIMELESS CRAFT,<br/>MODERN SOUL.",
    description: "Discover our new collection of heritage-inspired clothing, redefined for today."
  },
  {
    image: "https://images.unsplash.com/photo-1550614000-4b95d4ed6dfa?q=80&w=2070&auto=format&fit=crop",
    alt: "Heritage Collection Look 2",
    title: "ELEVATED<br/>EVERYDAY.",
    description: "Experience premium materials and uncompromising attention to detail in every stitch."
  },
  {
    image: "https://images.unsplash.com/photo-1539109136881-3be0616acf4b?q=80&w=2070&auto=format&fit=crop",
    alt: "Heritage Collection Look 3",
    title: "REFINED<br/>AESTHETICS.",
    description: "Curated styles that seamlessly transition from day to evening with effortless elegance."
  },
  {
    image: "https://images.unsplash.com/photo-1583391733958-d25e07fac04f?q=80&w=2070&auto=format&fit=crop",
    alt: "Heritage Collection Look 4",
    title: "UNCOMPROMISING<br/>QUALITY.",
    description: "Handcrafted pieces built to last a lifetime of wear, designed for the modern individual."
  }
];
---

<section class="w-full relative bg-[#1c2024] text-[#f4f4f5] overflow-hidden min-h-screen flex items-center pt-20 pb-12 rounded-b-[2.5rem]">
  <!-- Dummy targets to prevent GSAP warnings from landing.facade.ts -->
  <div style="display:none;" data-animate="hero-title-1"></div>
  <div style="display:none;" data-animate="hero-title-2"></div>
  <div style="display:none;" data-animate="hero-caption"></div>
  <div style="display:none;" data-animate="hero-cta"></div>

  <div class="max-w-[1800px] mx-auto w-full px-6 md:px-12 lg:px-16 grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
    
    <!-- Main Content Swiper (Cols 1-11) -->
    <div class="lg:col-span-11 w-full relative group">
      <div class="swiper main-hero-swiper w-full rounded-sm overflow-hidden">
        <div class="swiper-wrapper">
          {carouselData.map((item) => (
            <div class="swiper-slide w-full">
              <div class="grid grid-cols-1 lg:grid-cols-11 gap-10 items-center">
                <!-- Left: Image -->
                <div class="lg:col-span-5 h-[50vh] md:h-[60vh] lg:h-[75vh] w-full relative overflow-hidden rounded-sm">
                  <img 
                    class="w-full h-full object-cover object-center transition-transform duration-[10s] ease-out hover:scale-105 slide-image" 
                    src={item.image} 
                    alt={item.alt}
                    loading="eager"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                </div>

                <!-- Right: Typography and CTA -->
                <div class="lg:col-span-6 flex flex-col justify-center px-2 lg:px-8 py-8 lg:py-0 content-wrapper">
                  <h1 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] xl:text-[6.5rem] font-bold uppercase leading-[0.95] tracking-tight mb-6 text-[#eae9e4] slide-title" set:html={item.title}></h1>
                  <p class="text-[#a1a1aa] text-base md:text-lg max-w-lg mb-10 font-light leading-relaxed slide-desc">
                    {item.description}
                  </p>
                  <a href="/shop" class="bg-[#b46d54] hover:bg-[#9c5e48] text-white px-8 py-4 rounded-full w-fit text-sm font-medium tracking-wide transition-colors duration-300 uppercase shadow-lg shadow-[#b46d54]/20 slide-cta">
                    Explore Collection
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Right: Thumbnails (Col 12) -->
    <div class="hidden lg:flex lg:col-span-1 flex-col justify-center items-center h-[75vh] relative ml-auto pr-4">
      <button class="thumb-prev mb-6 text-[#71717a] hover:text-[#f4f4f5] transition-colors p-2" aria-label="Previous Slide">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 15.75 7.5-7.5 7.5 7.5" />
        </svg>
      </button>
      
      <div class="swiper thumb-hero-swiper h-[50vh] w-24">
        <div class="swiper-wrapper">
          {carouselData.map((item) => (
            <div class="swiper-slide h-auto cursor-pointer rounded-sm overflow-hidden border border-transparent transition-all duration-300 opacity-60 hover:opacity-100">
              <div class="aspect-[3/4] w-full">
                <img class="w-full h-full object-cover object-center" src={item.image} alt={`${item.alt} thumbnail`} />
              </div>
            </div>
          ))}
        </div>
      </div>
      
      <button class="thumb-next mt-6 text-[#71717a] hover:text-[#f4f4f5] transition-colors p-2" aria-label="Next Slide">
         <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .thumb-hero-swiper .swiper-slide-thumb-active {
    opacity: 1;
    border-color: #b46d54;
  }

  .swiper-slide .slide-title,
  .swiper-slide .slide-desc,
  .swiper-slide .slide-cta {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .swiper-slide-active .slide-title {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.2s;
  }

  .swiper-slide-active .slide-desc {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.4s;
  }

  .swiper-slide-active .slide-cta {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.6s;
  }

  .swiper-slide .slide-image {
    transform: scale(1.05);
    transition: transform 6s ease-out;
  }
  
  .swiper-slide-active .slide-image {
    transform: scale(1);
  }
</style>

<script>
  import Swiper from 'swiper';
  import { Navigation, Thumbs, EffectFade, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-fade';
  import 'swiper/css/navigation';
  import 'swiper/css/thumbs';

  function initHeroSwipers() {
    const thumbSwiperEl = document.querySelector('.thumb-hero-swiper');
    const mainSwiperEl = document.querySelector('.main-hero-swiper');

    if (!thumbSwiperEl || !mainSwiperEl) return;

    const thumbSwiper = new Swiper('.thumb-hero-swiper', {
      modules: [Navigation],
      direction: 'vertical',
      spaceBetween: 16,
      slidesPerView: 4,
      freeMode: true,
      watchSlidesProgress: true,
      navigation: {
        nextEl: '.thumb-next',
        prevEl: '.thumb-prev',
      },
    });

    new Swiper('.main-hero-swiper', {
      modules: [Thumbs, EffectFade, Autoplay],
      effect: 'fade',
      fadeEffect: {
        crossFade: true
      },
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
      },
      thumbs: {
        swiper: thumbSwiper,
      },
      autoHeight: true,
    });
  }

  document.addEventListener('DOMContentLoaded', initHeroSwipers);
  document.addEventListener('astro:page-load', initHeroSwipers);
</script>
