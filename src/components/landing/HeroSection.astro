---
import img1 from "../../assets/images/1000151766.jpg.jpeg";
import img2 from "../../assets/images/1000151768.jpg.jpeg";
import img3 from "../../assets/images/1000151774.jpg.jpeg";
import img4 from "../../assets/images/1000151776.jpg.jpeg";
import img5 from "../../assets/images/1000152082.jpg.jpeg";
import img6 from "../../assets/images/1000152095.jpg.jpeg";

const images = [img1.src, img2.src, img3.src, img4.src, img5.src, img6.src];
---

<section class="relative w-full h-screen bg-dark overflow-hidden flex items-center justify-center pt-16">
  
  <!-- Continuous Image Marquee -->
  <div class="absolute inset-0 flex items-center overflow-x-hidden opacity-70 group">
     <div class="flex animate-marquee-hero whitespace-nowrap h-[110vh] items-center group-hover:[animation-play-state:paused]">
        {images.map(img => (
            <div class="h-[60vh] md:h-[80vh] aspect-[3/4] flex-shrink-0 mx-2 md:mx-4 overflow-hidden relative cursor-crosshair">
                <img src={img} alt="Triostepdkhyber Lookbook" class="w-full h-full object-cover filter grayscale hover:grayscale-0 hover:scale-105 transition-all duration-[1.5s] ease-out" />
            </div>
        ))}
     </div>
     <div class="flex animate-marquee-hero whitespace-nowrap h-[110vh] items-center group-hover:[animation-play-state:paused]" aria-hidden="true">
        {images.map(img => (
            <div class="h-[60vh] md:h-[80vh] aspect-[3/4] flex-shrink-0 mx-2 md:mx-4 overflow-hidden relative cursor-crosshair">
                <img src={img} alt="Triostepdkhyber Lookbook" class="w-full h-full object-cover filter grayscale hover:grayscale-0 hover:scale-105 transition-all duration-[1.5s] ease-out" />
            </div>
        ))}
     </div>
  </div>

  <div class="absolute inset-0 bg-gradient-to-t from-dark/80 via-transparent to-dark/50 pointer-events-none"></div>

  <!-- Center Typography Overlay -->
  <div class="relative z-20 flex flex-col items-center justify-center text-center px-4 pointer-events-auto h-full pb-10">
      <h1 class="font-display text-[9vw] lg:text-[7vw] font-bold uppercase tracking-tighter text-white leading-none mb-4 mix-blend-overlay drop-shadow-2xl">TRIOSTEPDKHYBER</h1>
      <p class="text-white text-xs md:text-sm font-bold tracking-[0.4em] uppercase mb-12 max-w-xl text-center">
          The New Standard of Heritage Footwear
      </p>
      <a href="/shop" class="bg-white text-dark px-12 py-5 text-xs font-bold uppercase tracking-[0.2em] hover:bg-gray-200 transition-all duration-500 hover:shadow-2xl hover:scale-105">
          Enter The Shop
      </a>
  </div>
  
  <style>
      @keyframes marquee-hero {
          0% { transform: translateX(0%); }
          100% { transform: translateX(-100%); }
      }
      .animate-marquee-hero {
          animation: marquee-hero 45s linear infinite;
      }
  </style>
</section>
