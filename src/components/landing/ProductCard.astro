---
import WishlistToggle from '../shop/ui/WishlistToggle';

export interface Props {
	id: number;
	title: string;
	priceLabel: string;
	imageSrc: string;
	imageAlt: string;
	bottomBorderMd?: boolean; // Kept for backwards compatibility but ignored in UI
}

const {
	id,
	title,
	priceLabel,
	imageSrc,
	imageAlt,
} = Astro.props;
---

<div class="relative group flex flex-col w-full h-full">
  <div class="relative aspect-[3/4] overflow-hidden bg-[#F2F2F2] mb-4">
    <div class="absolute top-4 right-4 z-20 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
      <WishlistToggle productId={id} client:load />
    </div>
</div>
